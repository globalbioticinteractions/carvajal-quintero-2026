@article{
doi:10.1126/sciadv.adu6540,
author = {Juan D. Carvajal-Quintero  and Maria Dornelas  and Lise Comte  and Juliana Herrera-Pérez  and Pablo A. Tedesco  and Xingli Giam  and Ulrich Brose  and Jonathan M. Chase },
title = {Degradation of fish food webs in the Anthropocene},
journal = {Science Advances},
volume = {12},
number = {8},
pages = {eadu6540},
year = {2026},
doi = {10.1126/sciadv.adu6540},
URL = {https://www.science.org/doi/abs/10.1126/sciadv.adu6540},
eprint = {https://www.science.org/doi/pdf/10.1126/sciadv.adu6540},
abstract = {Global change reshapes biodiversity through shifts in species composition, richness, and body size. How these shifts combine to alter higher-level ecological processes within food webs can have important implications for entire ecosystems. However, the strength and direction of these shifts will depend on combinations of ways that species and trait compositions change through time. We combine long-term data from ~15,000 freshwater and marine fish communities (1949–2019) with information about their size, diets, and trophic status to evaluate how food webs change through time at local spatial scale. We found that selective species turnover driven by body size reductions is associated with widespread alteration to fish food web topology and function, including increased connectance and generalism, leading to higher predation pressure and increased prey vulnerability. Food webs were also less modular. These changes extend across food web trophic structures, causing a cascading shift in the proportion of species across trophic levels. Our study highlights complex biodiversity responses to confluent changes across multiple facets. The decrease in body size driven by the selective species turnover is widely altering fish food web topology and function.}}

